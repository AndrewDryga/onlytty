# Go runner
/onlytty
/dist/
*.test
*.out

# Elixir relay (portal/)
portal/_build/
portal/deps/
portal/*.ez
portal/onlytty-*.tar
erl_crash.dump

# Terraform (infra/) — keep .terraform.lock.hcl committed; ignore state + secrets
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/terraform.tfvars
infra/crash*.log

# Self-host bundle: the example ships; a real .env holds SECRET_KEY_BASE — never commit it
selfhost/.env

# Node test deps
node_modules/

# OS / editor
.DS_Store
*.swp

# coop working state (commit knowledge, ignore state)
.agent/*
!.agent/rules/
!.agent/skills/

# Per-agent tool dirs are local only — not published. The shared, public agent
# layer lives in AGENTS.md, the CLAUDE.md/GEMINI.md symlinks to it, and
# .agent/skills + .agent/rules (kept above). Each agent's skills symlink
# regenerates on disk pointing at the committed .agent/skills.
.claude/
.codex/
.gemini/
