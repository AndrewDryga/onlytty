# Copy to .env (docker compose reads it automatically) and fill both values in.

# The public hostname for your relay. Point its DNS A/AAAA record at this host; Caddy
# gets a Let's Encrypt certificate for it on first boot. It also ends up in every link
# the runner prints (https://relay.example.com/s/<id>#<secret>).
ONLYTTY_DOMAIN=relay.example.com

# Phoenix signing secret. Generate one and keep it stable across restarts and upgrades:
#
#   openssl rand -base64 64 | tr -d '\n'
#
# Sessions are in-memory, so rotating it loses nothing terminal-related — but on a
# multi-node cluster the Erlang cookie is derived from it, so every node must share the
# same value.
SECRET_KEY_BASE=
