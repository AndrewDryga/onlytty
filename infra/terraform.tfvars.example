# Copy to terraform.tfvars (gitignored) and fill in. Then:
#   terraform init -backend-config="bucket=<your-tf-state-bucket>"
#   terraform apply

project_id      = "my-gcp-project"
region          = "us-central1"
zone            = "us-central1-a"
domain          = "onlytty.example.com"
acme_email      = "you@example.com"
machine_type    = "e2-small"
# Published by the release workflow (.github/workflows/release.yml) to GHCR.
# (Artifact Registry is also provisioned if you'd rather push there.)
container_image = "ghcr.io/andrewdryga/onlytty:latest"

# Lock SSH down to your own IP in production, e.g.:
# ssh_source_ranges = ["203.0.113.4/32"]
