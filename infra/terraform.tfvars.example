# Copy to terraform.tfvars (gitignored) and fill in. Then:
#   terraform login
#   terraform init
#   terraform apply
#
# If the Terraform Cloud workspace uses remote execution, set these values as
# workspace variables instead; .terraformignore excludes local *.tfvars files.

project_id = "onlytty"
region     = "us-central1"
domain     = "onlytty.com"
dns_name   = "onlytty.com." # trailing dot — the Cloud DNS managed zone

# Dedicated OnlyTTY subnet. Change only if it overlaps another VPC you peer with.
subnet_cidr = "10.80.0.0/24"

# Public GHCR image, published by the release workflow (.github/workflows/release.yml).
container_image = "ghcr.io/andrewdryga/onlytty:latest"

machine_type = "e2-small"

# Low-cost default: one VM. To scale out, set instance_count > 1 and provide a
# dns_cluster_query name that resolves to all relay instance IPs.
instance_count     = 1
dns_cluster_query = ""

# SSH is via IAP only — no ssh_source_ranges to set.
